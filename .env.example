# Core app
TI_DEBUG=false
TI_DATABASE_URL=sqlite:////app/data/torrent_intake.db

# qBittorrent connection
TI_QBT_HOST=http://qbittorrent:8080
TI_QBT_USERNAME=admin
TI_QBT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
TI_QBT_VERIFY_CERTIFICATE=false
TI_QBT_REQUEST_TIMEOUT_SECONDS=20

# Intake behavior and tagging
TI_INTAKE_CATEGORY=intake
TI_MANAGED_TAG=torrent_intake
TI_AUTO_CREATE_FINAL_CATEGORY=true

# Container path model (must stay aligned with README)
TI_LOCAL_STAGING_ROOT=/staging-local
TI_NAS_STAGING_ROOT=/downloads/torrent-intake/staging
TI_FINAL_PARENT_PREFIX=/downloads

# NAS override threshold for jobs requested as local staging
TI_LOCAL_MAX_GIB=200

# Polling/event timing
TI_POLLING_INTERVAL_SECONDS=300
TI_COMPLETION_GRACE_SECONDS=15
TI_COMPLETION_EVENT_TOKEN=

# Malware scan command
TI_CLAMDSCAN_BINARY=clamscan
TI_CLAMDSCAN_ARGS=--infected --no-summary --recursive

# Telegram alerts are only sent when malware is detected and deleted.
# Leave blank to disable alerts.
TI_TELEGRAM_BOT_TOKEN=
TI_TELEGRAM_CHAT_ID=
